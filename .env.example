# Single account
JUNIOR_EMAIL=you@junior.so
JUNIOR_PASSWORD=yourpassword
JUNIOR_TENANT_ID=tm_xxxx

# Multi-account rotation (overrides single account above)
# JUNIOR_ACCOUNTS=[{"email":"a@b.com","password":"pass1","tenant_id":"tm_xxx"},{"email":"b@b.com","password":"pass2","tenant_id":"tm_xxx"}]

# Optional: protect your endpoint with an API key
# API_KEY=sk-your-secret-key

# Junior.so base URL (default: https://junior.so)
# JUNIOR_BASE_URL=https://junior.so
