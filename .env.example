# Get your token from browser (open DevTools > Network > send a message > copy headers)
JUNIOR_TOKEN=your_token_here
JUNIOR_UID=u_xxxxxxxxxxxxxxxxxx
JUNIOR_TENANT_ID=tm_xxxxxxxxxxxx

# Multi-account rotation (overrides single account above)
# JUNIOR_ACCOUNTS=[{"token":"tok1","uid":"u_xxx1","tenant_id":"tm_xxx"},{"token":"tok2","uid":"u_xxx2","tenant_id":"tm_xxx"}]

# Optional: protect your endpoint with an API key
# API_KEY=sk-your-secret-key

# Junior.so base URL (default: https://junior.so)
# JUNIOR_BASE_URL=https://junior.so

# See GET_TOKEN.md for step-by-step instructions on getting your token
